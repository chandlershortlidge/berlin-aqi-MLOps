# Required for src.ingest / src.refresh — get at explore.openaq.org/register
OPENAQ_API_KEY=

# AWS credentials (local dev / local deploy). On EC2, prefer an instance
# role over static keys so nothing is baked into env files or images.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1

# MLflow — only needed during training / registration, NOT at serving time
# (the production image bakes the model in — see src.bundle).
MLFLOW_TRACKING_URI=

# Email alerting for monitor threshold crossings. Leave blank to disable.
# For Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_PASSWORD=<app-password>.
# For AWS SES: SMTP_HOST=email-smtp.<region>.amazonaws.com, SMTP_PORT=587,
# and the user/pass come from an SES SMTP credential.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=
ALERT_MIN_INTERVAL_SECONDS=3600
